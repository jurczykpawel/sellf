{
  "name": "admin-panel",
  "version": "2026.5.3",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "chflags -R nouchg,nohidden .next 2>/dev/null; rm -rf .next 2>/dev/null; true",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "lint:migrations": "bun run scripts/lint-migrations.ts",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/smoke --project=chromium --workers=2",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:api": "vitest run --config vitest.config.api.ts",
    "test:api:watch": "vitest --config vitest.config.api.ts",
    "test:config": "vitest run --config vitest.config.config.ts",
    "sync:playerstack": "scripts/sync-playerstack.sh",
    "test:a11y": "playwright test --project=accessibility",
    "test:visual": "playwright test --project=visual-mobile --project=visual-tablet --project=visual-laptop --project=visual-wide --project=visual-qhd --project=visual-4k",
    "test:visual:review": "playwright test --project=visual-mobile --project=visual-tablet --project=visual-laptop --project=visual-wide --project=visual-qhd --project=visual-4k && ../../../scripts/dev/visual-review",
    "t": "vitest run && playwright test tests/smoke --project=chromium --workers=2",
    "tt": "vitest run",
    "ttt": "scripts/run-pw.sh --project=chromium; scripts/kill-dev-server.sh; RATE_LIMIT_TEST_MODE=true scripts/run-pw.sh --project=rate-limiting --project=rate-limiting-v1",
    "tttt": "cd .. && npx supabase db reset && cd admin-panel && scripts/run-pw.sh --project=chromium; scripts/kill-dev-server.sh; RATE_LIMIT_TEST_MODE=true scripts/run-pw.sh --project=rate-limiting --project=rate-limiting-v1"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@floating-ui/react": "^0.27.19",
    "@marsidev/react-turnstile": "^1.5.2",
    "@next/eslint-plugin-next": "^16.2.6",
    "@stripe/react-stripe-js": "^6.4.0",
    "@stripe/stripe-js": "9.5.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "altcha": "^3.0.9",
    "altcha-lib": "^2.0.3",
    "bir1": "^4.2.0",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.8.0",
    "geist": "^1.7.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "react": "^19.2.6",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "undici": "^6.25.0",
    "vanilla-cookieconsent": "^3.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "undici": "^6.25.0",
    "yaml": "^2.8.3",
    "minimatch": "^3.1.5",
    "minimatch@^3": "^3.1.5",
    "minimatch@^9": "^9.0.9",
    "brace-expansion": "^1.1.14",
    "brace-expansion@^1": "^1.1.14",
    "brace-expansion@^2": "^2.1.0",
    "picomatch": "^4.0.4",
    "picomatch@^2": "^2.3.2",
    "picomatch@^4": "^4.0.4",
    "postcss": "^8.5.14",
    "postcss@<8.5.10": "^8.5.12",
    "fast-xml-builder": "^1.2.0",
    "fast-xml-parser": "^5.8.0",
    "flatted": "^3.4.2",
    "rollup": "^4.60.2",
    "vite": "^8.0.12",
    "vite@^7": "^7.3.2"
  }
}
