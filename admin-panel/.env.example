# =============================================================================
# Sellf — environment configuration
# =============================================================================
# Copy to .env.local and fill in. Grouped by: (1) REQUIRED, (2) auto-generated
# secrets, (3) captcha, (4) security/proxy, (5) optional integrations,
# (6) URLs, (7) feature toggles, (8) legal/embed/license, (9) webhooks,
# (10) Stripe checkout tuning, (11) MCP server.
#
# When deployed via StackPilot, the install/update script auto-generates every
# secret in section 2 and sets NODE_ENV + TRUSTED_PROXY. Deploying elsewhere
# (Vercel/Netlify/bare) — set those yourself.
# =============================================================================


# =============================================================================
# 1. REQUIRED — the app will not work without these
# =============================================================================

# --- Supabase (database + auth) ---
# Server reads SUPABASE_*; client reads NEXT_PUBLIC_SUPABASE_* (set both, same value).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here   # bypasses RLS — NEVER expose to client
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Stripe (payments) — choose ONE method ---
# METHOD 1 (env): set the keys here. METHOD 2 (DB): leave blank and use the
# Settings → Payments wizard (stores keys encrypted via APP_ENCRYPTION_KEY).
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# Webhook signing secret: usually NOT needed here — register the webhook from
# the admin panel (Settings → Payments → "Register webhook"); Sellf stores it
# encrypted in the DB. Set only if you prefer the env path (e.g. CI/Stripe CLI).
# STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# --- Site URL (redirects, auth callbacks, magic links, email links) ---
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Runtime environment ---
# Production startup asserts this is set. StackPilot sets it via PM2 ecosystem.
NODE_ENV=production


# =============================================================================
# 2. AUTO-GENERATED SECRETS
# =============================================================================
# StackPilot install/update generates all of these automatically. Generate
# manually elsewhere. DO NOT change once set — rotating breaks existing data
# (see each note). Commit none of these.

# AES-256-GCM key encrypting every DB-stored secret: Stripe (DB-mode) key,
# webhook signing secret, GUS / Currency API keys. Losing/rotating it makes all
# encrypted secrets undecryptable. Generate: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# HMAC binding a Stripe session/PI to its (user_id, product_id) tuple so a
# leaked clientSecret cannot mutate another session's metadata. Production
# refuses to boot without it (>=16 chars). Generate: openssl rand -base64 32
CHECKOUT_BINDING_SECRET=

# HMAC for the per-product login-wall handoff token (content gating). Required
# only if you use the login-wall snippet. Generate: openssl rand -hex 32
LOGINWALL_SECRET=

# Bearer token for /api/cron (scheduled jobs: access-expiry webhooks, webhook
# log cleanup). Point your scheduler at /api/cron with Authorization: Bearer.
# Generate: openssl rand -base64 32
CRON_SECRET=


# =============================================================================
# 3. CAPTCHA — bot protection on signup / checkout
# =============================================================================
# Priority: Turnstile (if both keys set) > ALTCHA (if HMAC key set) > NONE.
# Self-hosted: ALTCHA recommended (no external account). Supabase Cloud: also
# configure the same provider in the Supabase Dashboard.

# --- ALTCHA (self-hosted, HMAC proof-of-work, zero external deps) ---
# Generate: openssl rand -hex 32
ALTCHA_HMAC_KEY=

# --- Cloudflare Turnstile (overrides ALTCHA when both keys present) ---
# Keys: https://dash.cloudflare.com/turnstile
CLOUDFLARE_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Dev-only test mode — forces captcha to a fixed outcome (no real verification).
# Modes: ALWAYS_PASSES_VISIBLE | ALWAYS_BLOCKS_VISIBLE | ALWAYS_PASSES_INVISIBLE
#        | ALWAYS_BLOCKS_INVISIBLE | INTERACTIVE_CHALLENGE
# TURNSTILE_TEST_MODE=ALWAYS_PASSES_VISIBLE
# NEXT_PUBLIC_TURNSTILE_TEST_MODE=ALWAYS_PASSES_VISIBLE


# =============================================================================
# 4. SECURITY / REVERSE PROXY
# =============================================================================

# Set true when Sellf runs behind a reverse proxy that appends the real client
# IP to X-Forwarded-For (Caddy, nginx, Traefik, Cloudflare). Production refuses
# to boot without it. Effect: rate limiting + audit logs use the real IP.
# Bind the Node port to localhost so the upstream port cannot be reached
# directly with a forged XFF. StackPilot sets this automatically.
TRUSTED_PROXY=true

# PM2 memory limits (StackPilot sets these automatically on first deploy).
# SELLF_PM2_MAX_MEMORY — PM2 kills+restarts the process if RSS exceeds this.
#   Default: 512M. Raise to 1G on servers with ≥2 GB RAM.
# SELLF_NODE_MAX_OLD_SPACE — Node.js V8 heap limit in MB. Set to ~80% of
#   SELLF_PM2_MAX_MEMORY so GC kicks in before PM2 force-restarts the process.
#   Default: 400. Raise to 800 when SELLF_PM2_MAX_MEMORY=1G.
SELLF_PM2_MAX_MEMORY=512M
SELLF_NODE_MAX_OLD_SPACE=400

# Skip the HSTS header (default: HSTS enabled). Only set if terminating TLS
# somewhere that should not advertise HSTS.
# DISABLE_HSTS=true

# Allow plain-HTTP outgoing webhook URLs (default: HTTPS only). Dev convenience.
# ALLOW_HTTP_WEBHOOKS=true

# Force rate limiting ON in dev/test (default: off in dev, on in production).
# RATE_LIMIT_TEST_MODE=true


# =============================================================================
# 5. OPTIONAL INTEGRATIONS — only if you use the feature
# =============================================================================

# --- GUS REGON API (Polish company data) — env or DB-wizard (METHOD 2) ---
# Register: https://api.stat.gov.pl/Home/RegonApi
# GUS_API_KEY=your_gus_api_key_here
# Test env (also auto-detected if key starts with 'abcde'):
# GUS_API_TEST_MODE=false

# --- Currency exchange rates ---
# Provider: exchangerate-api (free 1500/mo) | ecb (free EU) | fixer (paid) | manual
NEXT_PUBLIC_CURRENCY_PROVIDER=manual
# API key for exchangerate-api / fixer (not needed for ecb/manual):
# CURRENCY_API_KEY=

# --- Upstash Redis (distributed rate limiting + cache; falls back to DB) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- OAuth social login ---
# Comma-separated providers shown on login (also enable each in Supabase).
# Supported: google, github, discord, twitter, azure, facebook, apple
# Empty = magic link only.
OAUTH_PROVIDERS=


# =============================================================================
# 6. URLs / DOMAINS — aliases, fall back to SITE_URL
# =============================================================================
# MAIN_DOMAIN — used for CORS / origin checks (e.g. demo.sellf.app).
# MAIN_DOMAIN=localhost:3000
# NEXT_PUBLIC_BASE_URL / NEXT_PUBLIC_APP_URL — payment-redirect aliases.
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000


# =============================================================================
# 7. FEATURE TOGGLES
# =============================================================================

# Demo mode — blocks destructive admin actions + enables password login.
# Refuses to boot in production if true. (NEXT_PUBLIC_ drives the UI banner.)
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false
# Required when intentionally running DEMO_MODE on a production build.
# ALLOW_PRODUCTION_DEMO_MODE=true

# E2E test mode — enables password login for Playwright. Refuses to boot in prod.
# E2E_MODE=true

# Supabase free-tier keep-alive — daily no-op ping so the project does not pause
# after 7 days idle (production-only). Opt out on paid/self-hosted Postgres.
# SUPABASE_KEEP_ALIVE=false

# Disposable email filter (signup).
DISPOSABLE_EMAIL_FILTER_ENABLED=true
DISPOSABLE_EMAIL_CACHE_TTL=3600000   # blocklist cache TTL (ms)
DISPOSABLE_EMAIL_WHITELIST=          # comma-separated domains to always allow
DISPOSABLE_EMAIL_BLACKLIST=          # comma-separated domains to always block
# Allow disposable emails in dev (bypass filter):
# DISPOSABLE_EMAIL_ALLOW_IN_DEV=true


# =============================================================================
# 8. LEGAL / EMBED / LICENSE / DOWNLOADS
# =============================================================================

# Terms / Privacy — /terms and /privacy redirect here if set.
# TERMS_OF_SERVICE_URL=https://example.com/terms-of-service.pdf
# PRIVACY_POLICY_URL=https://example.com/privacy-policy.pdf

# Embed checkout origin allowlist (DB primary, this is the env fallback).
# Comma-separated full origins, no path/wildcards.
# SELLF_EMBED_ALLOWED_ORIGINS=https://lm.techskills.academy,https://tco.sellf.app

# License key for tier-gated features (free|registered|pro|business). DB-first,
# env fallback.
# SELLF_LICENSE_KEY=

# Extra hosts allowed as product download URLs (extends built-in S3/R2/GDrive/
# Dropbox/Bunny allowlist). Subdomain match is automatic. Public (in JS bundle).
# NEXT_PUBLIC_SELLF_ALLOWED_DOWNLOAD_DOMAINS=lm.techskills.academy,assets.example.com


# =============================================================================
# 9. WEBHOOKS (outgoing)
# =============================================================================
# Delivery queue driver: supabase (DB queue, default) | upstash (needs Redis above).
# WEBHOOK_QUEUE_DRIVER=supabase
# Delete delivery logs older than N days (cron). Default 30.
# WEBHOOK_LOG_RETENTION_DAYS=30


# =============================================================================
# 10. STRIPE CHECKOUT TUNING (advanced — all optional, sensible defaults)
# =============================================================================
# Read at BUILD time (next.config.ts) and exposed as NEXT_PUBLIC_STRIPE_*.
# Set the non-prefixed name; the build mirrors it. Defaults shown.
# STRIPE_THEME=night                         # stripe | night | flat
# STRIPE_LABELS=floating                     # above | floating
# STRIPE_PAYMENT_METHODS=blik,p24,card       # ordered, comma-separated
# STRIPE_BLIK_SETUP_FUTURE_USAGE=off_session # off_session | on_session
# STRIPE_LAYOUTS_DEFAULT=tabs                # tabs | accordion | auto
# STRIPE_SESSION_EXPIRES_HOURS=24
# STRIPE_SESSION_BILLING_ADDRESS_COLLECTION=auto  # auto | required
# STRIPE_SESSION_AUTOMATIC_TAX_ENABLED=true
# STRIPE_SESSION_TAX_ID_COLLECTION_ENABLED=true
# STRIPE_RATE_LIMIT_MAX_REQUESTS=10
# STRIPE_RATE_LIMIT_WINDOW_MINUTES=1
# Collect TOS acceptance in checkout (also configure in Stripe Dashboard):
STRIPE_COLLECT_TERMS_OF_SERVICE=false
# Custom error strings: STRIPE_ERROR_* (e.g. STRIPE_ERROR_INVALID_EMAIL) —
# see next.config.ts for the full list; defaults are English messages.


# =============================================================================
# 11. MCP SERVER (Claude Desktop integration) — only for mcp-server/
# =============================================================================
# Both required to start the MCP server. Not used by the web app.
# SELLF_API_KEY=sf_live_xxx
# SELLF_API_URL=https://your-shop.example.com
