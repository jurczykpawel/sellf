# Encryption Key (Required for METHOD 2 of Stripe and GUS API)
# Generate encryption key with: openssl rand -base64 32
# CRITICAL: Never commit this key to version control
# This key encrypts sensitive API keys (Stripe, GUS) stored in database
APP_ENCRYPTION_KEY=your_generated_encryption_key_here

# Stripe Configuration - Choose ONE method:
#
# METHOD 1 (Recommended for developers, Docker, CI/CD):
# Set STRIPE_SECRET_KEY directly in .env file
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ----- Stripe webhook signing secret -----
# Usually not needed: register the webhook from the admin panel
# (Settings → Payments → "Register webhook"). Sellf stores the signing
# secret encrypted in the DB and reads it from there first.
# Set this env var only if you prefer the env-config path (e.g. CI deploy
# scripted via Stripe CLI) instead of clicking the admin button.
# STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_COLLECT_TERMS_OF_SERVICE=false # Set to true if you want to collect TOS acceptance during checkout, proper configuration is required in the Stripe dashboard as well
#
# METHOD 2 (Recommended for non-technical users):
# Use the Settings wizard in admin panel (requires APP_ENCRYPTION_KEY)
#
# Both methods are fully supported. Choose what works best for you.

# GUS REGON API Configuration (Polish company data) - Choose ONE method:
#
# METHOD 1 (Recommended for developers, Docker, CI/CD):
# Set GUS_API_KEY directly in .env file
GUS_API_KEY=your_gus_api_key_here
# Optional: Set to 'true' to use test environment (wyszukiwarkaregontest.stat.gov.pl)
# Test key for development: abcde12345abcde12345 (automatically uses test environment)
GUS_API_TEST_MODE=false
#
# METHOD 2 (Recommended for non-technical users):
# Use the Settings wizard in admin panel (requires APP_ENCRYPTION_KEY)
#
# Both methods are fully supported. Choose what works best for you.
# Register for API key at: https://api.stat.gov.pl/Home/RegonApi

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ----- Supabase free-tier keep-alive -----
# Supabase pauses free-tier projects after 7 days of zero activity. Sellf runs a
# daily no-op ping (HEAD count on `products`, ~5-20 ms) to keep the DB awake.
# Production-only (skipped in dev). Opt-out only if you self-host Postgres
# or are on a paid Supabase plan and want one less timer in your logs.
# SUPABASE_KEEP_ALIVE=false

# Site Configuration
SITE_URL=http://localhost:3000

# ===== Embed Checkout Origin Allowlist =====
# DB primary, env fallback. Used when seller_embed_settings is empty.
# Comma-separated list of full origins (https://domain.tld), no path/wildcards.
# Example for TSA solo:
#   SELLF_EMBED_ALLOWED_ORIGINS=https://lm.techskills.academy,https://tco.sellf.app
# Phase 2 marketplace: leave unset, use seller_embed_settings table.
SELLF_EMBED_ALLOWED_ORIGINS=

# =============================================================================
# CAPTCHA CONFIGURATION
# =============================================================================
# Sellf supports two captcha providers. Detection is automatic:
#   1. Turnstile keys set → uses Cloudflare Turnstile
#   2. ALTCHA_HMAC_KEY set → uses ALTCHA (self-hosted, zero external deps)
#   3. Neither → no captcha (development only, warns in production)
#
# For self-hosted deployments, ALTCHA is recommended (no Cloudflare account needed).
# For Supabase Cloud deployments, use Turnstile (also configure in Supabase Dashboard).

# --- Option A: ALTCHA (Recommended for self-hosted) ---
# Generate key with: openssl rand -hex 32
# No external services needed — pure HMAC-based proof-of-work
ALTCHA_HMAC_KEY=

# --- Option B: Cloudflare Turnstile ---
# Get keys from: https://dash.cloudflare.com/turnstile
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Development Testing Mode (optional - defaults to ALWAYS_PASSES_VISIBLE)
# Change this to test different scenarios without code changes
TURNSTILE_TEST_MODE=ALWAYS_PASSES_VISIBLE
# Available test modes:
# ALWAYS_PASSES_VISIBLE - Always succeeds (visible widget)
# ALWAYS_BLOCKS_VISIBLE - Always fails (visible widget)
# ALWAYS_PASSES_INVISIBLE - Always succeeds (invisible widget)
# ALWAYS_BLOCKS_INVISIBLE - Always fails (invisible widget)
# INTERACTIVE_CHALLENGE - Forces interactive challenge (visible widget)

# Available dummy secret keys (for Supabase GoTrue captcha configuration):
# 1x0000000000000000000000000000000AA - Always passes verification
# 2x0000000000000000000000000000000AA - Always fails verification
# 3x0000000000000000000000000000000AA - Returns "token already spent" error


# OAuth Social Login (Optional)
# Comma-separated list of providers to show on the login page.
# Each provider must be enabled in Supabase Dashboard (or config.toml for local dev)
# with a valid Client ID and Secret from the provider's developer console.
# Supported: google, github, discord, twitter, azure, facebook, apple
# Leave empty (or remove) to show only the magic link form.
OAUTH_PROVIDERS=

# Additional Download URL Hosts (extends the built-in allowlist)
# Comma-separated hostnames allowed as product download URLs, in addition to the
# built-in providers (S3, R2, GDrive, Dropbox, Bunny CDN, etc).
# Use this when hosting files on your own domain (e.g. lead magnets on your CDN).
# Subdomain match is automatic: 'example.com' also accepts 'cdn.example.com'; only
# the configured hostname or a direct subdomain qualifies.
# Public — values appear in the JS bundle. File URLs are visible to buyers anyway.
# NEXT_PUBLIC_SELLF_ALLOWED_DOWNLOAD_DOMAINS=lm.techskills.academy,assets.example.com

# Demo Mode Configuration
# Set to 'true' to enable demo mode (blocks destructive admin actions)
# DEMO_MODE controls server-side (middleware, server actions)
# NEXT_PUBLIC_DEMO_MODE controls client-side (banner, UI hints)
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false

# Disposable Email Filter Configuration
DISPOSABLE_EMAIL_FILTER_ENABLED=true
DISPOSABLE_EMAIL_CACHE_TTL=3600000
DISPOSABLE_EMAIL_WHITELIST=
DISPOSABLE_EMAIL_BLACKLIST=

# Legal Documents URLs
# These URLs will be used for redirecting Terms of Service and Privacy Policy pages
TERMS_OF_SERVICE_URL=https://example.com/terms-of-service.pdf
PRIVACY_POLICY_URL=https://example.com/privacy-policy.pdf

# =============================================================================
# CURRENCY EXCHANGE RATE PROVIDER
# =============================================================================
# Choose provider: 'exchangerate-api' (free 1500/mo), 'ecb' (free EU rates), 
# 'fixer' (paid), or 'manual' (hardcoded fallback rates)
# Default: 'manual' if not set
NEXT_PUBLIC_CURRENCY_PROVIDER=manual

# API Key for ExchangeRate-API or Fixer.io (not needed for ECB/manual)
# Get free key at: https://www.exchangerate-api.com/
CURRENCY_API_KEY=

# =============================================================================
# REVERSE PROXY / RATE LIMITING
# =============================================================================
# Set TRUSTED_PROXY=true when Sellf runs behind a reverse proxy that injects
# the real client IP at the END of the X-Forwarded-For header (the standard
# behavior of Caddy, nginx with $proxy_add_x_forwarded_for, Traefik, HAProxy
# with `option forwardfor`, and Cloudflare).
#
# Effect when enabled:
#   - Rate limiting buckets by real client IP instead of a header fingerprint
#   - Audit logs (consent_logs, FB CAPI events, api_keys.last_used_ip) record
#     the real client IP
#
# Leave UNSET (or false) when:
#   - Node.js listens directly on a public interface, with no proxy in front
#   - You use a proxy that overwrites X-Forwarded-For instead of appending
#
# Production checklist:
#   1. Bind the Node port to localhost (or block it at the firewall) so
#      requests cannot bypass the proxy and inject a forged X-Forwarded-For
#      value directly on the upstream port.
#   2. If a CDN (Cloudflare, BunnyCDN, Fastly) sits in front of your origin
#      proxy, the CDN does NOT strip client-supplied X-Forwarded-For — it
#      forwards it as-is. Sellf compensates by reading the LAST hop in the
#      list, which is the value your origin proxy appends. As long as the
#      Node port is closed to the public internet, the last hop is trusted.
#   3. Optional defense in depth: configure your origin proxy to strip
#      inbound X-Forwarded-For from non-private clients
#      (e.g. `trusted_proxies private_ranges` in Caddy).
TRUSTED_PROXY=

# CHECKOUT_BINDING_SECRET — server-side HMAC secret used to bind a Stripe
# session/PI to the (user_id, product_id) tuple it was created for. The
# /api/update-payment-metadata route refuses to mutate metadata unless the
# caller presents a valid binding token, so a leaked clientSecret alone is
# not enough to nadpisać metadata cudzej sesji.
#
# Generate once per deployment:
#   openssl rand -base64 32
#
# Production refuses to boot without it (>=16 chars). Rotating invalidates
# in-flight checkout sessions (acceptable — Stripe sessions are short-lived).
CHECKOUT_BINDING_SECRET=

# Login Wall — HMAC secret for the per-product content-gating handoff token.
# Required if you generate the login wall snippet from the admin UI.
# Generate with: openssl rand -hex 32
# Rotation: pick a fresh value and restart the app. In-flight tokens become
# invalid immediately; visitors are bounced back through /loginwall/protect
# and re-issued a new token transparently.
LOGINWALL_SECRET=
